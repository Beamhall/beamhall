# Beamhall runtime configuration — copy to /etc/beamhall/beamhall.env and edit.
# All values have appliance defaults; set the ones marked REQUIRED for production.

# --- core ---
BEAMHALL_HTTP_ADDR=:8443
BEAMHALL_BASE_DOMAIN=beamhall.acme.internal     # REQUIRED: your appliance hostname
BEAMHALL_DATA_DIR=/var/lib/beamhall
BEAMHALL_LOG_LEVEL=info

# --- secret root key (out-of-band) ---
# Do NOT set BEAMHALL_SECRET_KEY_FILE here. The unit delivers
# /etc/beamhall/secret.key as a systemd credential and points beamhalld at it
# via Environment=BEAMHALL_SECRET_KEY_FILE=%d/secret.key (%d expands only inside
# the unit, never inside this EnvironmentFile). beamhalld loads it read-only and
# refuses to start if missing.
# Create the age key once, e.g.
#   docker run --rm ghcr.io/filosottile/age age-keygen   (or `age-keygen`)
# and install the AGE-SECRET-KEY-... line at /etc/beamhall/secret.key (0400 root).

# --- identity provider (OAuth/OIDC) — set the ISSUER to enable MCP + Admin ---
# Copy the issuer VERBATIM from the IdP's discovery doc (trailing slashes matter).
# JWKS is resolved automatically via OIDC discovery — no path to configure.
# See docs/idp-setup.md for the per-IdP recipe (Keycloak/Okta/Entra).
BEAMHALL_OAUTH_ISSUER=https://idp.acme.internal/realms/beamhall
# Defaults to https://<base-domain>/mcp — must match the token audience the IdP mints
# (the IdP MUST add this to `aud`; e.g. a Keycloak audience mapper).
#BEAMHALL_OAUTH_AUDIENCE=https://beamhall.acme.internal/mcp
# Optional: pin the JWKS endpoint to skip discovery (IdP without a discovery doc).
#BEAMHALL_OAUTH_JWKS_URL=https://idp.acme.internal/realms/beamhall/protocol/openid-connect/certs
#BEAMHALL_OAUTH_DISCOVERY_URL=https://idp.acme.internal/realms/beamhall/.well-known/openid-configuration
# Optional: the IdP realm role that elevates a caller to IT admin over MCP (in
# addition to the admin:it scope). Lets a public admin-agent client grant admin by
# role assignment without requesting the hidden admin:it scope. Default beamhall-it.
#BEAMHALL_OAUTH_ADMIN_ROLE=beamhall-it

# Admin console (set the client to enable /admin; requires the admin:it scope).
BEAMHALL_ADMIN_CLIENT_ID=beamhall-admin
BEAMHALL_ADMIN_CLIENT_SECRET=change-me
#BEAMHALL_ADMIN_SCOPES=openid admin:it
#BEAMHALL_ADMIN_BASE_URL=https://beamhall.acme.internal

# --- governance ---
# Explicit IT-approval gate for promote_to_live (PLAN §10). When on, an agent's
# promote_to_live files a request a DIFFERENT IT operator must approve (four-eyes)
# via approve_promotion before the beam goes live. Recommended on for regulated
# pilots. Off = promote immediately (scope/role-gated).
#BEAMHALL_PROMOTE_APPROVAL=on

# --- gateway (Caddy) ---
BEAMHALL_CADDY_ADMIN=http://127.0.0.1:2019
BEAMHALL_GATEWAY_LISTEN=:80,:443
# TLS mode: on = public ACME (real domain, internet-reachable); internal = mint
# from Caddy's local CA for an internal domain like *.beamhall.internal (install
# the gateway root CA on client workstations); off = plain HTTP.
BEAMHALL_GATEWAY_TLS=on

# --- build pipeline (the dedicated non-remapped build daemon + internal registry) ---
BEAMHALL_BUILD_DOCKER_HOST=unix:///run/docker-build.sock
BEAMHALL_CNB_BUILDER=paketobuildpacks/builder-jammy-base:latest
BEAMHALL_REGISTRY=127.0.0.1:5000
# Air-gapped builds (docs/air-gapped.md): use pre-mirrored images, don't pull.
#BEAMHALL_PACK_PULL_POLICY=if-not-present
#BEAMHALL_CNB_RUN_IMAGE=127.0.0.1:5000/paketo/run-jammy-base:1

# --- managed Postgres (enables create_database) ---
# Admin DSN on loopback; the production password should itself come from a
# systemd credential or vault, not be written here in the clear.
#BEAMHALL_PG_ADMIN_DSN=postgres://postgres:CHANGE-ME@127.0.0.1:5433/postgres?sslmode=disable
BEAMHALL_PG_BEAM_HOST=bh-postgres

# --- egress always-deny (host IP + management subnet, on top of metadata/link-local) ---
#BEAMHALL_EGRESS_ALWAYS_DENY=10.0.0.5/32,10.0.0.0/24
