{
  "realm": "beamhall",
  "enabled": true,
  "sslRequired": "none",
  "accessTokenLifespan": 3600,
  "clientScopes": [
    {
      "name": "beamhall-audience",
      "description": "Adds the Beamhall resource URI to aud (required by the backplane).",
      "protocol": "openid-connect",
      "attributes": { "include.in.token.scope": "false", "display.on.consent.screen": "false" },
      "protocolMappers": [
        {
          "name": "beamhall-aud",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "config": { "included.custom.audience": "${AUDIENCE}", "access.token.claim": "true", "id.token.claim": "false" }
        },
        {
          "name": "beamhall-sub-from-username",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-property-mapper",
          "config": { "user.attribute": "username", "claim.name": "sub", "jsonType.label": "String", "access.token.claim": "true", "id.token.claim": "false", "introspection.token.claim": "true" }
        }
      ]
    },
    { "name": "beamhalls:read",  "protocol": "openid-connect", "attributes": { "include.in.token.scope": "true", "display.on.consent.screen": "false" } },
    { "name": "beams:write",     "protocol": "openid-connect", "attributes": { "include.in.token.scope": "true", "display.on.consent.screen": "false" } },
    { "name": "beams:deploy",    "protocol": "openid-connect", "attributes": { "include.in.token.scope": "true", "display.on.consent.screen": "false" } },
    { "name": "beams:operate",   "protocol": "openid-connect", "attributes": { "include.in.token.scope": "true", "display.on.consent.screen": "false" } },
    { "name": "beams:promote",   "protocol": "openid-connect", "attributes": { "include.in.token.scope": "true", "display.on.consent.screen": "false" } },
    { "name": "secrets:write",   "protocol": "openid-connect", "attributes": { "include.in.token.scope": "true", "display.on.consent.screen": "false" } },
    { "name": "resources:write", "protocol": "openid-connect", "attributes": { "include.in.token.scope": "true", "display.on.consent.screen": "false" } },
    { "name": "logs:read",       "protocol": "openid-connect", "attributes": { "include.in.token.scope": "true", "display.on.consent.screen": "false" } },
    { "name": "metrics:read",    "protocol": "openid-connect", "attributes": { "include.in.token.scope": "true", "display.on.consent.screen": "false" } },
    { "name": "admin:it",        "protocol": "openid-connect", "attributes": { "include.in.token.scope": "true", "display.on.consent.screen": "false" } }
  ],
  "roles": {
    "realm": [
      { "name": "beamhall-it", "description": "Beamhall IT administrator — elevates a caller to IT admin over MCP (and the Admin console). Assign only to IT operators." }
    ]
  },
  "clients": [
    {
      "clientId": "beamhall-admin",
      "name": "Beamhall Admin console",
      "enabled": true,
      "publicClient": false,
      "secret": "${ADMIN_SECRET}",
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "redirectUris": ["${ADMIN_REDIRECT}"],
      "defaultClientScopes": ["beamhall-audience", "admin:it"],
      "optionalClientScopes": []
    },
    {
      "clientId": "beamhall-agent",
      "name": "Beamhall agent (Claude Code)",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "redirectUris": ["http://localhost/*", "http://127.0.0.1/*", "http://localhost:*/*", "http://127.0.0.1:*/*"],
      "attributes": { "pkce.code.challenge.method": "S256" },
      "defaultClientScopes": ["beamhall-audience"],
      "optionalClientScopes": ["beamhalls:read", "beams:write", "beams:deploy", "beams:operate", "beams:promote", "secrets:write", "resources:write", "logs:read", "metrics:read", "admin:it", "offline_access"]
    },
    {
      "clientId": "beamhall-admin-agent",
      "name": "Beamhall admin agent (IT operators)",
      "description": "Public PKCE client for IT operators' agents. IT-admin elevation is gated by the beamhall-it realm role (per user), not a scope, so a non-IT user here gets no admin.",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "redirectUris": ["http://localhost/*", "http://127.0.0.1/*", "http://localhost:*/*", "http://127.0.0.1:*/*"],
      "attributes": { "pkce.code.challenge.method": "S256" },
      "defaultClientScopes": ["beamhall-audience", "beamhalls:read", "beams:write", "beams:deploy", "beams:operate", "beams:promote", "secrets:write", "resources:write", "logs:read", "metrics:read"],
      "optionalClientScopes": ["admin:it", "offline_access"],
      "protocolMappers": [
        {
          "name": "realm-roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "config": {
            "claim.name": "realm_access.roles",
            "jsonType.label": "String",
            "multivalued": "true",
            "access.token.claim": "true",
            "id.token.claim": "false",
            "userinfo.token.claim": "false"
          }
        }
      ]
    },
    {
      "clientId": "beamhall-idp-admin",
      "name": "Beamhall IdP administration (backplane service account)",
      "description": "Confidential service-account client the backplane uses to administer this realm (admin_* IdP tools). Beamhall holds this secret; agents never do.",
      "enabled": true,
      "publicClient": false,
      "secret": "${IDP_ADMIN_SECRET}",
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": true
    }
  ],
  "users": [
    {
      "username": "service-account-beamhall-idp-admin",
      "enabled": true,
      "serviceAccountClientId": "beamhall-idp-admin",
      "clientRoles": { "realm-management": ["realm-admin"] }
    },
    {
      "username": "builder",
      "enabled": true,
      "email": "builder@beamhall.pilot",
      "emailVerified": true,
      "firstName": "Pilot", "lastName": "Builder",
      "realmRoles": ["offline_access"],
      "credentials": [{ "type": "password", "value": "${BUILDER_PASSWORD}", "temporary": false }]
    },
    {
      "username": "it-admin",
      "enabled": true,
      "email": "it-admin@beamhall.pilot",
      "emailVerified": true,
      "firstName": "Pilot", "lastName": "IT",
      "realmRoles": ["offline_access", "beamhall-it"],
      "credentials": [{ "type": "password", "value": "${IT_PASSWORD}", "temporary": false }]
    }
  ]
}
