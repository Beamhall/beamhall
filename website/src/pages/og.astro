---
// Social share card (1200x630). Rendered once to /og.png via headless Chrome
// (see website/README). Kept as a route so the card is reproducible; noindex.
import { Image } from "astro:assets";
import logo from "../assets/beamhall-logo.png";
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="robots" content="noindex" />
    <style>
      @font-face {
        font-family: "JetBrains Mono";
        font-weight: 400;
        src: url("/fonts/JetBrainsMono-Regular.woff2") format("woff2");
      }
      @font-face {
        font-family: "JetBrains Mono";
        font-weight: 700;
        src: url("/fonts/JetBrainsMono-Bold.woff2") format("woff2");
      }
      * { margin: 0; box-sizing: border-box; }
      html, body { width: 1200px; height: 630px; overflow: hidden; }
      .card {
        width: 1200px;
        height: 630px;
        /* flat base = the logo's own background, so the logo blends seamlessly
           (its cyan drop-shadow is the glow); a soft vignette only darkens the
           far corners, never the area behind the logo */
        background: #010312
          radial-gradient(125% 125% at 50% 44%, transparent 56%, rgba(0, 0, 0, 0.55));
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 22px;
        padding: 46px 80px;
        text-align: center;
        font-family: "JetBrains Mono", ui-monospace, monospace;
        color: #eaf1ff;
      }
      .card img {
        width: 256px;
        height: auto;
        filter: drop-shadow(0 16px 54px rgba(43, 212, 238, 0.30));
      }
      .headline {
        font-size: 44px;
        line-height: 1.25;
        font-weight: 700;
        max-width: 980px;
        color: #eaf1ff;
      }
      .headline b { color: #2bd4ee; font-weight: 700; }
      .sub {
        font-size: 25px;
        line-height: 1.4;
        font-weight: 400;
        max-width: 920px;
        color: #66728f;
      }
      .url {
        font-size: 23px;
        color: #2bd4ee;
        letter-spacing: 0.05em;
      }
    </style>
  </head>
  <body>
    <div class="card">
      <Image src={logo} alt="Beamhall" widths={[480]} sizes="350px" />
      <div class="headline">Agent-built apps, <b>infrastructure included</b>.</div>
      <div class="sub">
        Self-hosted · apps inherit data, identity &amp; secure connectivity.
      </div>
      <div class="url">beamhall.com</div>
    </div>
  </body>
</html>
