{
  "realm": "beamhall",
  "enabled": true,
  "accessTokenLifespan": 3600,
  "clientScopes": [
    {
      "name": "beamhall-audience",
      "description": "Adds the Beamhall resource URI to aud (the Keycloak audience-mapper requirement).",
      "protocol": "openid-connect",
      "attributes": { "include.in.token.scope": "true", "display.on.consent.screen": "false" },
      "protocolMappers": [
        {
          "name": "beamhall-aud",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "config": {
            "included.custom.audience": "https://lab.beamhall.internal/mcp",
            "access.token.claim": "true",
            "id.token.claim": "false"
          }
        }
      ]
    },
    {
      "name": "beams:deploy",
      "protocol": "openid-connect",
      "attributes": { "include.in.token.scope": "true", "display.on.consent.screen": "false" }
    },
    {
      "name": "secrets:write",
      "protocol": "openid-connect",
      "attributes": { "include.in.token.scope": "true", "display.on.consent.screen": "false" }
    }
  ],
  "clients": [
    {
      "clientId": "beamhall-agent",
      "enabled": true,
      "publicClient": false,
      "secret": "beamhall-agent-secret",
      "serviceAccountsEnabled": true,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": true,
      "defaultClientScopes": ["beams:deploy", "secrets:write"],
      "optionalClientScopes": ["beamhall-audience"]
    }
  ]
}
